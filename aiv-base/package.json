{
	"name": "aiv-base",
	"version": "0.1.0",
	"private": true,
	"description": "SCSS build workflow for the AIV Base WordPress starter theme.",
	"scripts": {
		"start": "sass --watch --style=expanded --source-map assets/scss:assets/css",
		"build": "sass --style=compressed --no-source-map assets/scss:assets/css"
	},
	"devDependencies": {
		"sass": "^1.89.2"
	}
}

